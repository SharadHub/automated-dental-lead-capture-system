# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/dental_clinic

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Anthropic / Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Nodemailer (SMTP for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_clinic_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="Dental Clinic <your_clinic_email@gmail.com>"

# Owner/Manager notification email
OWNER_EMAIL=owner@dentalclinic.com

# Gmail IMAP (for reading incoming emails)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_clinic_email@gmail.com
IMAP_PASS=your_app_password_here

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Clinic info
CLINIC_NAME=Bright Smile Dental Clinic
CLINIC_PHONE=+977-1-4567890
CLINIC_ADDRESS=Lalitpur, Nepal
